# CapitalAI Audit Crawler — Environment Config
# Copy to .env — NEVER commit .env to git

# Ollama (local — no cloud, no paid API)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Crawl limits
CLIENT_CRAWL_DEPTH=3
COMPETITOR_CRAWL_DEPTH=2
MAX_PAGES_CLIENT=150
MAX_PAGES_COMPETITOR=60

# Output
REPORTS_DIR=reports
